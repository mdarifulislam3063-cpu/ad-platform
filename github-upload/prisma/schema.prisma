generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum AdSourceType {
  DIRECT
  ADSTERRA
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          String    @default("user")
  balance       Float     @default(0.0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  adViews       AdView[]
  payments      Payment[]
}

model Ad {
  id          String        @id @default(cuid())
  title       String
  sourceType  AdSourceType  @default(DIRECT)

  // DIRECT Ad related fields
  videoUrl    String?       // file URL or YouTube ID
  videoType   String?       // "direct" or "youtube"
  advertiser  String?
  costPerView Float?
  userShare   Float?

  // ADSTERRA Ad related fields
  adTagUrl    String?       // VAST tag URL from Adsterra

  // Common
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  views       AdView[]
}

model AdView {
  id        String   @id @default(cuid())
  userId    String
  adId      String
  watchedAt DateTime @default(now())
  ip        String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  method      String
  phoneNumber String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}